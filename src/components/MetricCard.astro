---
const { label, value, description } = Astro.props;
---

<div class="bg-base-100 shadow-sm p-5 border border-base-300 rounded-[3px]">
  <div class="text-slate-500 text-xs uppercase tracking-widest">{label}</div>
  <div class="mt-3 font-semibold text-base-content text-2xl">{value}</div>
  <p class="mt-2 text-sm text-base-content">{description}</p>
</div>
