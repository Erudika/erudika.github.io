---
import marketing from "../data/site-data.json";
import { Image } from "astro:assets";

const { email } = Astro.props;
const { person = marketing.site.pages.about.keyPeople.people.filter((p) => p.email === email)[0] } = Astro.props;

---
<div class="flex items-center gap-3 bg-base-100 px-4 py-4 border border-base-300 rounded-[10px]">
    <div>
        <Image src={import(`../images/${person.avatar}.jpeg`)}
        inferSize
        alt={person.name}
        loading="lazy"
        class="flex justify-center items-center bg-indigo-600 rounded-full w-16 h-16 font-semibold text-white text-sm"/>
    </div>
    <div class="w-56 font-semibold text-sm text-base-content">{person.name}
        <br>
        <span class="font-normal text-xs">{person.role}</span>
        {person.bio && <p class="hidden mt-1 font-normal text-xs text-base-content/70">{person.bio}</p>}
        {(person.linkedin || person.github) && (
          <div class="hidden flex justify-center gap-2 mt-1">
            {person.linkedin && (
              <a 
                href={person.linkedin} 
                target="_blank"
                rel="noopener noreferrer"
                class="text-sky-600 hover:text-sky-800 text-xs"
                aria-label="LinkedIn">
                in
              </a>
            )}
            {person.github && (
              <a
                href={person.github} 
                target="_blank" 
                rel="noopener noreferrer" 
                class="text-sky-600 hover:text-sky-800 text-xs" 
                aria-label="GitHub">
                  gh
              </a>
            )}
          </div>
        )}
    </div>
</div>
    
