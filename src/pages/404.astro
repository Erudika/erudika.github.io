---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site-data.json";
---

<BaseLayout title="Page Not Found | Erudika" description="The page you are looking for does not exist." noindex={true}>
  <section class="py-24">
    <div class="text-center section-shell">
      <h1 class="font-semibold text-base-content text-6xl">404</h1>
      <p class="mt-4 text-base-content text-lg">Page not found</p>
      <p class="mt-2 text-base-content/60">The page you are looking for does not exist or has been moved.</p>
      <a href="/" class="inline-flex mt-8 text-white btn btn-primary">Go to homepage</a>
    </div>
  </section>
</BaseLayout>
