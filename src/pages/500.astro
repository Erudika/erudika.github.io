---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Server Error | Erudika" description="Something went wrong on our end." noindex={true}>
  <section class="py-24">
    <div class="text-center section-shell">
      <h1 class="font-semibold text-base-content text-6xl">500</h1>
      <p class="mt-4 text-base-content text-lg">Something went wrong</p>
      <p class="mt-2 text-base-content/60">An unexpected error occurred. Please try again later.</p>
      <a href="/" class="inline-flex mt-8 text-white btn btn-primary">Go to homepage</a>
    </div>
  </section>
</BaseLayout>
