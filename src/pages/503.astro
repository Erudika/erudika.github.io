---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Temporarily Offline | Erudika" description="Site is under maintenance." noindex={true}>
  <section class="py-24">
    <div class="text-center section-shell">
      <h1 class="font-semibold text-base-content text-6xl">503</h1>
      <p class="mt-4 text-base-content text-lg">Under Maintenance</p>
      <p class="mt-2 text-base-content/60">We&rsquo;ll be back shortly. Please check back later.</p>
      <a href="/" class="inline-flex mt-8 text-white btn btn-primary">Go to homepage</a>
    </div>
  </section>
</BaseLayout>
