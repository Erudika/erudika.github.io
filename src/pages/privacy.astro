---
import BaseLayout from "../layouts/BaseLayout.astro";
import marketing from "../data/site-data.json";

const { privacy } = marketing.site.pages;
---

<BaseLayout
  title={marketing.site.meta.privacy.title}
  description={marketing.site.meta.privacy.description}
>
  <section class="py-16">
    <div class="section-shell">
      <p class="font-semibold text-slate-500 text-xs uppercase tracking-[0.3em]">{privacy.eyebrow}</p>
      <h1 class="mt-3 font-semibold text-base-content text-4xl">{privacy.title}</h1>
      <p class="mt-3 text-sm text-base-content/60">Effective date: {privacy.effectiveDate}</p>
      <p class="mt-6 text-base-content">
        {privacy.intro}
      </p>

      <div class="space-y-8 mt-8 text-sm text-base-content">
        {privacy.sections.map((section) => (
          <section>
            <h2 class="font-semibold text-base-content text-lg">{section.title}</h2>
            {section.paragraphs?.map((paragraph) => (
              <p class="mt-2">{paragraph}</p>
            ))}
            {section.items?.length ? (
              <ul class="space-y-1 mt-2 pl-5 list-disc">
                {section.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            ) : null}
            {section.email && section.emailLabel ? (
              <p class="mt-2">
                {section.emailLabel}:{" "}
                <a class="text-sky-700" href={`mailto:${section.email}`}>
                  {section.email}
                </a>
              </p>
            ) : null}
            {section.contactIntro && section.email ? (
              <p class="mt-2">
                {section.contactIntro}{" "}
                <a class="text-sky-700" href={`mailto:${section.email}`}>
                  {section.email}
                </a>
              </p>
            ) : null}
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
